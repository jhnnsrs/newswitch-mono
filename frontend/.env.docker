# Used by docker-compose (`vite --mode docker`). Overrides .env AND .env.local.
#
# These two sets of URLs are NOT interchangeable:

# Browser-facing (host -> published port). Baked into the client JS.
VITE_BACKEND_URL=http://localhost:8099
VITE_WEBSOCKET_URL=ws://localhost:8099/ws

# Build-time codegen (frontend container -> backend container, over the compose network).
VITE_SCHEMA_IMPLEMENTATION_URL=http://backend:8099/schemas/implementations
VITE_SCHEMA_STATES_URL=http://backend:8099/schemas/states
VITE_SCHEMA_LOCKS_URL=http://backend:8099/schemas/locks
